MCP_ENV=development
MCP_DEBUG=true
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_TRANSPORT=stdio

# Database
MCP_DB_URL=sqlite+aiosqlite:///./mcp.db

# Redis (optional)
MCP_REDIS_URL=redis://localhost:6379/0

# Auth
MCP_AUTH_SECRET_KEY=CHANGE-ME-IN-PRODUCTION-USE-A-STRONG-SECRET
MCP_AUTH_ALGORITHM=HS256
MCP_AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Observability
MCP_OBS_LOG_LEVEL=INFO
MCP_OBS_ENABLE_TRACING=false
MCP_OBS_SERVICE_NAME=mcp-sdk

# Agent Platform
MCP_MAX_AGENTS=100
MCP_AGENT_TIMEOUT_SECONDS=300
MCP_ENABLE_A2A=true
MCP_ENABLE_A2B=true
MCP_ENABLE_B2B=true
MCP_ENABLE_B2C=true
